{
  "name": "@conty/design-system-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Conty Design System monorepo (tokens, UI and Storybook).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "storybook": "npm run storybook --workspace @conty/storybook",
    "build-storybook": "npm run build-storybook --workspace @conty/storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.7.2",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  },
  "engines": {
    "node": ">=20"
  }
}
